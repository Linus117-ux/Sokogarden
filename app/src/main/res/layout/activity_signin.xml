<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Signin"
    android:orientation="vertical">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sigin"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textColor="#EDEDED"/>
<!--    Below is a cardveiw-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        app:cardElevation="10dp">
<!--        Below is a linear layout that shall align items vertically-->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    >
<!--    Below is the email edit text -->
    <EditText
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:hint="Enter email address"
    android:id="@+id/email"
    android:layout_margin="8dp"
    android:padding="11dp"
    android:textColor="#000"
    android:textColorHint="#000"/>
    <!--    Below is the password edit text -->
    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter your password"
        android:id="@+id/password"
        android:layout_margin="8dp"
        android:padding="11dp"
        android:textColor="#000"
        android:textColorHint="#000"/>
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Signin"
        android:textSize="25sp"
        android:padding="10dp"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="8dp"
        android:textColor="#E1CDD8"
        android:backgroundTint="#051232"
        android:id="@+id/signinBtn"
        android:layout_marginRight="50dp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dont Have an Accout? Signup"
        android:textAlignment="center"
        android:textSize="23sp"
        android:layout_marginTop="25dp"
        android:textColor="#000"
        android:id="@+id/singuptxt" />

</LinearLayout>


    </androidx.cardview.widget.CardView>
</LinearLayout>